[ButtonSizing]
ButtonSpacingLeft=3
ButtonSpacingRight=5
FullHeightButtonSpacingLeft=1
FullHeightButtonSpacingRight=1
FullHeightButtonWidthMarginLeft=3
FullHeightButtonWidthMarginRight=8
IntegratedRoundedRectangleBottomPadding=1
LockFullHeightButtonSpacingLeftRight=true

[ShadowStyle]
ShadowColor=0,170,255
ShadowStrength=179

[SystemIconGeneration]
KlassyDarkIconThemeInherits=Pure-Adwaita-Dark
KlassyIconThemeInherits=Pure-Adwaita-Light

[TitleBarOpacity]
ActiveTitleBarOpacity=70
InactiveTitleBarOpacity=85

[TitleBarSpacing]
PercentMaximizedTopBottomMargins=100
TitleBarBottomMargin=1.7
TitleBarTopMargin=1.7
TitleSidePadding=2

[Windeco]
AnimationsSpeedRelativeSystem=-4
BoldButtonIcons=BoldIconsHiDpiOnly
ButtonIconStyle=StyleSystemIconTheme
ButtonShape=ShapeIntegratedRoundedRectangleGrouped
DrawBackgroundGradient=true
IconSize=IconVeryLarge
MatchTitleBarToApplicationColor=true
SystemIconSize=SystemIcon24
WindowCornerRadius=11
