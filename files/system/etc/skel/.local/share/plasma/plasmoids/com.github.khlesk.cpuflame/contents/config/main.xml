<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0       http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
  <kcfgfile name=""/>
  <group name="General">
    <entry name="lowTemp" type="Int">
      <default>40</default>
    </entry>
    <entry name="highTemp" type="Int">
      <default>90</default>
    </entry>
    <entry name="updateInterval" type="Int">
      <default>2000</default>
    </entry>
    <entry name="tempSensorPath" type="String">
      <default/>
    </entry>
    <entry name="flameStyle" type="Int">
      <default>0</default>
    </entry>
    <entry name="renderBackend" type="Int">
      <default>0</default>
    </entry>
    <entry name="showLoadText" type="Bool">
      <default>true</default>
    </entry>
    <entry name="showTempText" type="Bool">
      <default>true</default>
    </entry>
    <entry name="maxTextSize" type="Int">
      <default>24</default>
    </entry>
    <entry name="transparentBackground" type="Bool">
      <default>false</default>
    </entry>
    <entry name="widgetFps" type="Int">
      <default>15</default>
    </entry>
    <entry name="batteryFps" type="Int">
      <default>5</default>
    </entry>
    <entry name="particleSize" type="Int">
      <default>10</default>
    </entry>
    <entry name="particleCount" type="Int">
      <default>60</default>
    </entry>
    <entry name="panelWidth" type="Int">
      <default>80</default>
    </entry>
